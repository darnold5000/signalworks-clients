# Set to true temporarily to log auth/session flow (server + browser)
DEBUG_AUTH=false
NEXT_PUBLIC_DEBUG_AUTH=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — branded client invite emails (from Signal Works, not Supabase)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@hiresignalworks.com

# App URL — used for Stripe return URLs in local dev. Invite links always use
# https://clients.hiresignalworks.com unless this is set to a non-localhost URL.
NEXT_PUBLIC_APP_URL=https://clients.hiresignalworks.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Set to true only after Tax head office address is configured in Stripe
STRIPE_AUTOMATIC_TAX=false

# Plan Price IDs (from Stripe Dashboard → Products, test mode)
STRIPE_PRICE_PERSONAL_BRAND=
STRIPE_PRICE_LAUNCH=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_FOUNDING_CLIENT=
